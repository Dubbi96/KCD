# ---- builder ----
FROM node:20-alpine AS builder
WORKDIR /build
COPY KCD/dashboard/package.json KCD/dashboard/package-lock.json* ./
RUN npm install
COPY KCD/dashboard/ ./
RUN npx vite build

# ---- nginx ----
FROM nginx:alpine
COPY --from=builder /build/dist /usr/share/nginx/html
COPY KCD/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
